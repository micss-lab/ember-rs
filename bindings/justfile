target-dir := "`cargo metadata --format-version 1 | jq -r '.target_directory'`"

default:
    @ echo -n "\"Bindings\" module defines following "
    @ just --list

build:
    cargo build --release --target xtensa-esp32-none-elf --package ember-bindings -Zbuild-std=core,alloc

update-arduino-lib: build
    echo {{target-dir}}
    cp {{target-dir}}/xtensa-esp32-none-elf/release/libember.a ../arduino/libraries/Framework/src/esp32/FrameworkCore.a
    cp {{target-dir}}/bindings.hpp ../arduino/libraries/Framework/src/FrameworkCore.h
